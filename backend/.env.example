# ============================================================
# PRESCREVE-AI — Backend Environment Variables
# Copie para .env e preencha os valores reais
# ============================================================

# ── Banco de Dados ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/prescreve_ai?schema=public"

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET="troque-por-string-aleatoria-de-64-chars-minimo"
JWT_REFRESH_SECRET="troque-por-string-aleatoria-diferente-de-64-chars-minimo"

# ── Redis (opcional — sistema funciona sem Redis) ─────────────
# REDIS_URL="redis://localhost:6379"

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3001"

# ── Porta ─────────────────────────────────────────────────────
PORT=3000
